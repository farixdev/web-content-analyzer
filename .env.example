# Copy this file to ".env" (same folder) and paste your keys after the "=".
# The app loads .env automatically on every launch, so you enter keys once.
# .env is git-ignored, so your real keys are never committed.

# Serper.dev API key - removes the Google CAPTCHA in Search mode.
# Get a free key at https://serper.dev
SERPER_API_KEY=

# Groq API key - AI insights and the AI-generated outline headings.
# Get a free key at https://console.groq.com
GROQ_API_KEY=
